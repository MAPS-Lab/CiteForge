rd-number": ["733051066"]}]}, {"DOI": "10.13039/100002108", "name": "Friedreich\u2019s Ataxia Research Alliance", "doi-asserted-by": "crossref", "award": ["92133"], "award-info": [{"award-number": ["92133"]}], "id": [{"id": "10.13039/100002108", "id-type": "DOI", "asserted-by": "crossref"}]}, {"award": ["2013/07559\u20133"], "award-info": [{"award-number": ["2013/07559\u20133"]}], "id": [{"id": "https://ror.org/02ddkpn78", "id-type": "ROR", "asserted-by": "publisher"}]}, {"DOI": "10.13039/501100001809", "name": "National Natural Science Foundation of China", "doi-asserted-by": "crossref", "award": ["82071910"], "award-info": [{"award-number": ["82071910"]}], "id": [{"id": "10.13039/501100001809", "id-type": "DOI", "asserted-by": "crossref"}]}, {"name": "Senior Medical Talents Program of Chongqing for Young and Middle Aged", "award": ["514Z395"], "award-info": [{"award-number": ["514Z395"]}]}, {"name": "Young and Middle-Aged Senior Medical Talents Studio of Chongqing", "award": ["524Z28921"], "award-info": [{"award-number": ["524Z28921"]}]}, {"name": "Excellent Young Talent Fund of the First Affiliated Hospital of the Army Medical University", "award": ["2024YQBJ-2"], "award-info": [{"award-number": ["2024YQBJ-2"]}]}, {"DOI": "10.13039/501100001659", "name": "German Research Foundation", "doi-asserted-by": "crossref", "award": ["DE 2516/1-1"], "award-info": [{"award-number": ["DE 2516/1-1"]}], "id": [{"id": "10.13039/501100001659", "id-type": "DOI", "asserted-by": "crossref"}]}, {"DOI": "10.13039/501100001659", "name": "German Research Foundation", "doi-asserted-by": "crossref", "award": ["TI 239/17-1"], "award-info": [{"award-number": ["TI 239/17-1"]}], "id": [{"id": "10.13039/501100001659", "id-type": "DOI", "asserted-by": "crossref"}]}, {"name": "National Council of Science and Technology of Mexico", "award": ["A1-S-10669"], "award-info": [{"award-number": ["A1-S-10669"]}]}, {"name": "General Directorate of Academic Personnel Affairs Support Program for Research and Technological Innovation Projects", "award": ["IN208625"], "award-info": [{"award-number": ["IN208625"]}]}, {"id": [{"id": "https://ror.org/046keqp87", "id-type": "ROR", "asserted-by": "publisher"}]}, {"name": "NIH Big Data to Knowledge", "award": ["U54 EB020403"], "award-info": [{"award-number": ["U54 EB020403"]}]}, {"DOI": "10.13039/100000002", "name": "National Institutes of Health", "doi-asserted-by": "crossref", "award": ["R01MH123163"], "award-info": [{"award-number": ["R01MH123163"]}], "id": [{"id": "10.13039/100000002", "id-type": "DOI", "asserted-by": "crossref"}]}, {"DOI": "10.13039/100000002", "name": "National Institutes of Health", "doi-asserted-by": "crossref", "award": ["R01MH121246"], "award-info": [{"award-number": ["R01MH121246"]}], "id": [{"id": "10.13039/100000002", "id-type": "DOI", "asserted-by": "crossref"}]}, {"DOI": "10.13039/100000002", "name": "National Institutes of Health", "doi-asserted-by": "crossref", "award": ["R01MH116147"], "award-info": [{"award-number": ["R01MH116147"]}], "id": [{"id": "10.13039/100000002", "id-type": "DOI", "asserted-by": "crossref"}]}], "content-domain": {"domain": [], "crossmark-restriction": false}, "accepted": {"date-parts": [[2025, 8, 8]]}, "abstract": "<jats:title>Abstract</jats:title>\n                <jats:sec>\n                  <jats:title>Objective</jats:title>\n                  <jats:p>Spinocerebellar ataxia type 3 (SCA3) is a rare, inherited neurodegenerative disease. Here, we profile the spatial spread of atrophy across the whole brain, determine whether brain degeneration preferentially maps onto specific functional networks, and investigate the relationship between cerebellar and cerebral anatomical changes.</jats:p>\n                </jats:sec>\n                <jats:sec>\n                  <jats:title>Methods</jats:title>\n                  <jats:p>Whole-brain grey and white matter (GM and WM) voxel-based morphometry was performed on 408 individuals with SCA3 (82 pre-ataxic) and 293 controls. The SCA3 cohort was stratified by ataxia severity to investigate disease progression, with cerebellar GM atrophy mapped onto a task-based functional atlas. Volume was correlated with disease duration and intensity. Cerebrocerebellar volumetric covariance was assessed to determine whether atrophy was coupled between infra- and supratentorial regions.</jats:p>\n                </jats:sec>\n                <jats:sec>\n                  <jats:title>Results</jats:title>\n                  <jats:p>The pattern of atrophy is spatially consistent but progressive in magnitude across the disease course. The greatest atrophy was found in the pons, cerebellar WM, and cerebellar peduncles; correlations with disease severity and duration were also strongest in these regions. Cerebellar GM atrophy was greatest in functional regions associated with motor execution and planning, attention, and emotional processing. Sparse cerebral cortical atrophy appears only in the most severe disease subgroup, while striatal atrophy begins in the earliest stages. Reduced cerebrocerebellar structural covariance is observed in SCA3 participants versus controls.</jats:p>\n                </jats:sec>\n                <jats:sec>\n                  <jats:title>Interpretation</jats:title>\n                  <jats:p>While cerebellar and brainstem atrophy become more severe, the pattern of atrophy remains largely consistent as SCA3 progresses. Cerebellar GM degeneration occurs in regions associated with motor, cognitive, and affective control, in line with clinical presentation. Cerebellar atrophy is not directly mirrored by cerebral changes.</jats:p>\n                </jats:sec>", "DOI": "10.1101/2025.08.08.669370", "type": "posted-content", "created": {"date-parts": [[2025, 8, 9]], "date-time": "2025-08-09T07:55:17Z", "timestamp": 1754726117000}, "source": "Crossref", "is-referenced-by-count": 0, "title": "A Core Pattern of Cerebellar and Brainstem Degeneration and Reduced Cerebrocerebellar Structural Covariance in Spinocerebellar Ataxia Type 3 (SCA3): MRI Volumetrics from ENIGMA-Ataxia", "prefix": "10.64898", "author": [{"ORCID": "https://orcid.org/0000-0003-0579-0403", "authenticated-orcid": false, "given": "Jason W.", "family": "Robertson", "sequence": "first", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0003-1402-5877", "authenticated-orcid": false, "given": "Isaac", "family": "Adanyeguh", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0002-6442-1205", "authenticated-orcid": false, "given": "David J.", "family": "Arpin", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0001-7180-2869", "authenticated-orcid": false, "given": "Tetsuo", "family": "Ashizawa", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0002-3205-4631", "authenticated-orcid": false, "given": "Benjamin", "family": "Bender", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0001-9336-9568", "authenticated-orcid": false, "given": "Fernando", "family": "Cendes", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0009-0001-6671-3420", "authenticated-orcid": false, "given": "Xi", "family": "Chen", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0002-7824-8343", "authenticated-orcid": false, "given": "Giulia", "family": "Coarelli", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0003-4921-2939", "authenticated-orcid": false, "given": "L\u00e9o", "family": "Coutinho", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0002-2427-1302", "authenticated-orcid": false, "given": "Andreas", "family": "Deistung", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0002-6632-197X", "authenticated-orcid": false, "given": "Imis", "family": "Dogan", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0002-892