{"timestamp": 1771724086.4340012, "ttl_days": 90, "data": {"indexed": {"date-parts": [[2026, 1, 24]], "date-time": "2026-01-24T18:04:25Z", "timestamp": 1769277865933, "version": "3.49.0"}, "reference-count": 20, "publisher": "American Society for Microbiology", "issue": "5", "license": [{"start": {"date-parts": [[2025, 5, 20]], "date-time": "2025-05-20T00:00:00Z", "timestamp": 1747699200000}, "content-version": "vor", "delay-in-days": 0, "URL": "https://creativecommons.org/licenses/by/4.0/"}, {"start": {"date-parts": [[2025, 5, 20]], "date-time": "2025-05-20T00:00:00Z", "timestamp": 1747699200000}, "content-version": "tdm", "delay-in-days": 0, "URL": "https://journals.asm.org/non-commercial-tdm-license"}], "funder": [{"DOI": "10.13039/501100000024", "name": "Canadian Institutes of Health Research", "doi-asserted-by": "publisher", "award": ["191753"], "award-info": [{"award-number": ["191753"]}], "id": [{"id": "10.13039/501100000024", "id-type": "DOI", "asserted-by": "publisher"}]}, {"name": "U.S. Department of Agriculture\u2019s National Institute of Food and Agriculture", "award": ["7004439, ME022329"], "award-info": [{"award-number": ["7004439, ME022329"]}]}, {"DOI": "10.13039/100000002", "name": "National Institutes of Health", "doi-asserted-by": "publisher", "award": ["NIH/NIDDK 1R15DK133826-01"], "award-info": [{"award-number": ["NIH/NIDDK 1R15DK133826-01"]}], "id": [{"id": "10.13039/100000002", "id-type": "DOI", "asserted-by": "publisher"}]}, {"DOI": "10.13039/501100000038", "name": "Natural Sciences and Engineering Research Council of Canada", "doi-asserted-by": "publisher", "id": [{"id": "10.13039/501100000038", "id-type": "DOI", "asserted-by": "publisher"}]}, {"DOI": "10.13039/501100001804", "name": "Canada Research Chairs", "doi-asserted-by": "publisher", "id": [{"id": "10.13039/501100001804", "id-type": "DOI", "asserted-by": "publisher"}]}, {"name": "University of Guelph Institute of Environmental Research"}], "content-domain": {"domain": ["journals.asm.org"], "crossmark-restriction": true}, "published-print": {"date-parts": [[2025, 5, 20]]}, "abstract": "<jats:title>ABSTRACT</jats:title>\n          <jats:sec>\n            <jats:title/>\n            <jats:p>Microbiomes are essential for human, animal, plant, and ecosystem health. Despite widespread recognition of the importance of microbiomes, there is little attention paid to monitoring and safeguarding microbial ecologies on policy levels. We observe that microbiomes are deteriorating owing to practices at societal levels such as pesticide use in agriculture, air and water pollution, and overuse of antibiotics. Potential policy on these issues would cross multiple domains such as public health, environmental protection, and agriculture. We propose microbiome stewardship as a foundational concept that can act across policy domains to facilitate healthy microbiomes for human and ecosystem health. We examine challenges to be addressed and steps to take toward developing meaningful microbiome stewardship.</jats:p>\n          </jats:sec>", "DOI": "10.1128/msystems.00062-25", "type": "journal-article", "created": {"date-parts": [[2025, 4, 16]], "date-time": "2025-04-16T13:01:46Z", "timestamp": 1744808506000}, "update-policy": "https://doi.org/10.1128/asmj-crossmark-policy-page", "source": "Crossref", "is-referenced-by-count": 2, "title": "The case for microbiome stewardship: what it is and how to get there", "prefix": "10.1128", "volume": "10", "author": [{"ORCID": "https://orcid.org/0000-0002-9117-5150", "authenticated-orcid": false, "given": "Mallory J.", "family": "Choudoir", "sequence": "first", "affiliation": [{"name": "Department of Plant and Microbial Biology, North Carolina State University", "place": ["Raleigh, USA"]}]}, {"ORCID": "https://orcid.org/0000-0002-2615-8055", "authenticated-orcid": true, "given": "Suzanne L.", "family": "Ishaq", "sequence": "additional", "affiliation": [{"name": "School of Food and Agriculture, University of Maine", "place": ["Orono, USA"]}]}, {"ORCID": "https://orcid.org/0000-0002-5065-4980", "authenticated-orcid": false, "given": "Robert G.", "family": "Beiko", "sequence": "additional", "affiliation": [{"name": "Faculty of Computer Science and Institute for Comparative Genomics, Dalhousie University", "place": ["Halifax, Canada"]}]}, {"given": "Diego S.", "family": "Silva", "sequence": "additional", "affiliation": [{"name": "Faculty of Medicine and Health, University of Sydney School of Public Health", "place": ["Camperdown, Australia"]}]}, {"ORCID": "https://orcid.org/0000-0002-8716-327X", "authenticated-orcid": true, "given": "Emma", "family": "Allen-Vercoe", "sequence": "additional", "affiliation": [{"name": "Department of Molecular and Cellular Biology, University of Guelph", "place": ["Guelph, Canada"]}]}, {"ORCID": "https://orcid.org/0000-0002-9242-2061", "authenticated-orcid": true, "given": "Kieran C.", "family": "O\u2019Doherty", "sequence": "additional", "affiliation": [{"name": "Department of Psychology, University of Guelph", "place": ["Guelph, Canada"]}]}], "member": "235", "reference": [{"key": "e_1_3_3_2_2", "doi-asserted-by": "publisher", "DOI": "10.1038/s41586-022-05620-1"}, {"key": "e_1_3_3_3_2", "doi-asserted-by": "publisher", "DOI": "10.1016/j.fm.2019.103305"}, {"key": "e_1_3_3_4_2", "doi-asserted-by": "publisher", "DOI": "10.20517/mrr.2021.08"}, {"key": "e_1_3_3_5_2", "doi-asserted-by": "publisher", "DOI": "10.1128/msystems.01462-21"}, {"key": "e_1_3_3_6_2", "doi-asserted-by": "publisher", "DOI": "10.1016/j.envint.2020.105604"}, {"key": "e_1_3_3_7_2", "doi-asserted-by": "publisher", "DOI": "10.1126/sciadv.aba2578"}, {"key": "e_1_3_3_8_2", "doi-asserted-by": "publisher", "DOI": "10.1186/s40168-019-0714-6"}, {"key": "e_1_3_3_9_2", "doi-asserted-by": "publisher", "DOI": "10.1080/19490976.2022.2105096"}, {"key": "e_1_3_3_10_2", "doi-asserted-by": "publisher", "DOI": "10.1007/s40572-020-00263-8"}, {"key": "e_1_3_3_11_2", "doi-asserted-by": "publisher", "DOI": "10.1128/mSystem